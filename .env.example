# PaddleOCR-VL cloud API (https://aistudio.baidu.com)
PADDLEOCR_TOKEN=your_paddleocr_token_here

# OCR backend selection. Options:
#   paddleocr - PaddleOCR-VL cloud (default; uses PADDLEOCR_TOKEN above)
#   mineru    - MinerU cloud (uses MINERU_TOKEN below; better figure quality)
OCR_BACKEND=mineru

# MinerU cloud API token. Required if OCR_BACKEND=mineru.
# Get from https://mineru.net/
MINERU_TOKEN=your_mineru_token_here

# Vision LLM (OpenAI-compatible; default = Qwen-VL via DashScope)
LLM_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_VISION_API_KEY=your_dashscope_key_here
LLM_VISION_MODEL=qwen-vl-max-latest

# Text LLM (OpenAI-compatible; default = DeepSeek Reasoner)
# deepseek-reasoner: chain-of-thought model; best analysis quality (recommended)
# deepseek-chat: faster/cheaper; use when reasoner budget is exhausted
LLM_TEXT_BASE_URL=https://api.deepseek.com/v1
LLM_TEXT_API_KEY=your_deepseek_key_here
LLM_TEXT_MODEL=deepseek-reasoner

# Optional: cap max_tokens for every LLM call (output quality > cost).
# Per-stage defaults already favor generous budgets (8K-16K) so deepseek-reasoner's
# chain-of-thought tokens don't starve final content. Lower this to constrain spend
# or stay under a stricter quota; raise it only if your model truly supports more.
# LLM_MAX_TOKENS_CEILING=40000
