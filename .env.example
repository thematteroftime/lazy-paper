# PaddleOCR-VL cloud API (https://aistudio.baidu.com)
PADDLEOCR_TOKEN=your_paddleocr_token_here

# OCR backend selection. Options:
#   paddleocr - PaddleOCR-VL cloud (default; uses PADDLEOCR_TOKEN above)
#   mineru    - MinerU cloud (uses MINERU_TOKEN below; better figure quality)
OCR_BACKEND=mineru

# MinerU cloud API token. Required if OCR_BACKEND=mineru.
# Get from https://mineru.net/
MINERU_TOKEN=your_mineru_token_here

# Vision LLM (OpenAI-compatible; default = Qwen-VL via DashScope)
LLM_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_VISION_API_KEY=your_dashscope_key_here
LLM_VISION_MODEL=qwen-vl-max-latest

# Text LLM (OpenAI-compatible; default = DeepSeek Reasoner)
# deepseek-reasoner: chain-of-thought model; best analysis quality (recommended)
# deepseek-chat: faster/cheaper; use when reasoner budget is exhausted
LLM_TEXT_BASE_URL=https://api.deepseek.com/v1
LLM_TEXT_API_KEY=your_deepseek_key_here
LLM_TEXT_MODEL=deepseek-reasoner

# Embeddings LLM (v1.4+, used by s08 retriever for chunk vectors).
# Optional — if any of these are unset, the embeddings role falls back to
# the LLM_VISION_* credentials (works out-of-the-box when vision is
# DashScope, which already serves text-embedding-v3). Override only if
# your embeddings live on a separate endpoint.
# LLM_EMBEDDINGS_API_KEY=
# LLM_EMBEDDINGS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_EMBEDDINGS_MODEL=text-embedding-3-small

# Optional: cap max_tokens for every LLM call (output quality > cost).
# Per-stage defaults already favor generous budgets (8K-16K) so deepseek-reasoner's
# chain-of-thought tokens don't starve final content. Lower this to constrain spend
# or stay under a stricter quota; raise it only if your model truly supports more.
# LLM_MAX_TOKENS_CEILING=40000

# ───────────────────────────────────────────────────────────────────────────
# Strategy KL — high-quality section composer (v1.8.1 baseline + v1.10 figure_ids).
# The "core 3" below unlock per-section literature-citation recovery on benchmark
# papers (see docs/v1_8_validation_results.md, mean 15.0/17 on meng2024 ch01).
# The "v1.10 figure binding" group on top achieves true 100% figure embedding
# on multi-figure papers — see docs/v1_10_variant_comparison.md §3.M2.
# ───────────────────────────────────────────────────────────────────────────
# Core 3 (Strategy KL baseline — recommended for all production runs):
# LAZY_PAPER_STRUCTURED=1            # enable instructor-based compose + verifier
# LAZY_PAPER_KG_PROMPT=paper_kg_v3.md  # extract author + comparator + cited_by_paper
# LAZY_PAPER_BEST_OF_N=2             # 2 LLM samples per section, round-robin merge

# v1.10 figure binding (recommended for figure-rich papers; zero LLM cost,
# Jaccard-only relevance + 1 figure-retry per section when ≥50% figs unmentioned):
# LAZY_PAPER_FIGURE_BIND=1           # populate section_figures + figure-retry pass
# LAZY_PAPER_FIGURE_ID_WHITELIST=0   # opt OUT of unknown-fig_id text substitution
                                     # (v1.11+ default ON: unknown "Fig. N" in
                                     # claim.text replaced with "源论文相关图示"
                                     # so the reader doesn't see broken links;
                                     # set =0 to keep the original behavior)

# v1.11.1: author-attribution hardreject. Default OFF (advisory only — the
# claim is kept but recorded in critic_flags.yaml as
# `author_not_in_chunk_advisory`). When set to 1, any claim that names an
# author whose surname doesn't appear in the claim's cited chunks is
# dropped — useful once you've reviewed advisory output on your corpus and
# confirmed the precision is high enough not to discard valid claims.
# LAZY_PAPER_AUTHOR_HARDREJECT=1     # promote advisory → hard rejection

# Depth mode (opt-in — default keeps chapters concise per v1.11 design):
# The defaults above produce concise, precision-focused chapters. If you
# want longer sections with more discussion / more sample diversity:
# LAZY_PAPER_MIN_SECTION_CHARS=1200  # retry-when-short below this (default 500)
# LAZY_PAPER_BEST_OF_N=3             # 3 samples instead of 2 (override above)
# Note: more chars ≠ more quality. A precise 1-line claim often beats a
# 1000-char paraphrase. Use this only when you've inspected current
# output and judged it under-detailed for your use case.

# Fine-tuning knobs:
# LAZY_PAPER_VERIFIER_THRESHOLD=0.85 # min quote-vs-chunk match score
# LAZY_PAPER_RETRY_THRESHOLD=0.5     # post-verify coverage ≤ X triggers retry
# LAZY_PAPER_REQUIRED_CAP=5          # max required-mentions per non-survey section
# LAZY_PAPER_REQUIRED_CAP_SURVEY=12  # max required-mentions per survey section

# ───────────────────────────────────────────────────────────────────────────
# OCR backend tuning (defaults are sane for ~10-30 page papers).
# ───────────────────────────────────────────────────────────────────────────
# MINERU_BASE_URL=https://mineru.net/api/v4
# MINERU_TIMEOUT_S=1800        # hard deadline for MinerU polling
# MINERU_POLL_S=10             # poll interval
# PADDLEOCR_BASE_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
# PADDLEOCR_MODEL=PaddleOCR-VL-1.5
# PADDLEOCR_TIMEOUT_S=1800
# PADDLEOCR_POLL_S=5

# === v1.12 phase 1 — opt-in features ===

# PDFFigures 2 sidecar for caption-anchored figure numbering.
# Required only when running with --pdffigures2 flag.
# Set to "docker" to use the bundled docker wrapper (project policy: no host
# JVM install). Build the image once with:
#   docker build -f Dockerfile.pdffigures2 -t lazy-paper/pdffigures2:0.1.0 .
PDFFIGURES2_JAR=

# LightRAG-inspired entity dedup pass after KG extraction. When =1, merges
# variant author/material mentions ("Meng et al." == "Meng 2024") to defend
# against author misattribution at the extraction layer (vs. the verifier).
LAZY_PAPER_ENTITY_DEDUP=0
