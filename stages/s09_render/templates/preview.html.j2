<!DOCTYPE html>
<html lang="{{ doc.lang }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ doc.paper_title }} · 深度解读</title>
{% if katex_inline %}
<style>{{ katex_css_inline }}</style>
<script defer>{{ katex_js_inline }}</script>
{% else %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" crossorigin="anonymous">
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js" integrity="sha384-XjKyOOlGwcjNTAIQHIpgOno0Hl1YQqzUOEleOLALmuqehneUG+vnGctmUb0ZY0l8" crossorigin="anonymous"></script>
{% endif %}
<style>{{ styles | safe }}</style>
</head>
<body class="upgrade-on" data-theme="orange" data-lang="{{ doc.lang }}">

<header class="topbar">
  <span class="brand"><span class="dot"></span>lazy-paper</span>
  <span class="doc-title">{{ doc.paper_title }}</span>
  <span class="locator" id="locator"></span>
  <div class="controls">
    <label class="toggle" title="{{ '将含 \\frac/\\sum 或长度 >40 字符的行内公式自动升级为独立公式块' if doc.lang == 'zh' else 'Auto-upgrade long inline formulas to display blocks' }}">
      <input type="checkbox" id="upgradeToggle" checked>
      <span class="track"></span>
      <span>{{ '长公式自动升级' if doc.lang == 'zh' else 'Auto-upgrade math' }}</span>
    </label>
    <div class="swatches" role="group" aria-label="theme">
      <button class="sw-orange" data-theme="orange" aria-pressed="true" title="orange"></button>
      <button class="sw-teal" data-theme="teal" aria-pressed="false" title="teal"></button>
      <button class="sw-indigo" data-theme="indigo" aria-pressed="false" title="indigo"></button>
    </div>
  </div>
</header>

<div class="layout">
<nav class="toc" aria-label="contents">
  <p class="toc-label">Contents</p>
  <ol id="tocList"></ol>
</nav>

<article class="reader" id="reader">

  <div class="doc-head">
    <span class="eyebrow">{{ '深度论文解读' if doc.lang == 'zh' else 'Deep Paper Analysis' }}</span>
    <h1 class="paper-title">{{ doc.paper_title }}</h1>
    <div class="doc-meta">
      <span><b>{{ '章节' if doc.lang == 'zh' else 'Chapters' }}</b> {{ doc.chapters|length }}</span>
      <span class="sep">·</span>
      <span><b>{{ '语言' if doc.lang == 'zh' else 'Lang' }}</b> {{ doc.lang|upper }}</span>
      <span class="sep">·</span>
      <span><b>{{ '生成' if doc.lang == 'zh' else 'Generated by' }}</b> lazy-paper</span>
    </div>
  </div>

  {% for ch in doc.chapters %}
  <section class="chapter" id="ch-{{ loop.index }}" data-title="{{ ch.heading }}">
    <h2 class="chapter-heading"><span class="ch-num">{{ "%02d"|format(loop.index) }}</span>{{ ch.heading }}</h2>
    {% for block in ch.blocks %}
      {% if block.__class__.__name__ == 'Paragraph' %}
        <p class="body-paragraph">{{ render_paragraph(block.raw_text or block.text) }}</p>
      {% elif block.__class__.__name__ == 'FigureBlock' %}
        <figure class="figure-block">
          {% set imgs = block_images(block) %}
          {% if imgs|length > 1 %}
            <div class="fig-multi">
              {% for img_src in imgs %}
                <figure>
                  <img src="{{ img_src }}" alt="{{ block.label }} panel {{ loop.index }}">
                  <div class="sub-cap">({{ "abcdefgh"[loop.index0] }})</div>
                </figure>
              {% endfor %}
            </div>
          {% else %}
            <div class="fig-frame">
              <img src="{{ imgs[0] }}" alt="{{ block.label }}">
            </div>
          {% endif %}
          <figcaption class="caption"><span class="fig-tag">{{ block.label }}.</span> {{ block.caption }}</figcaption>
          {% if block.deep_observation %}
            <aside class="deep-obs">
              <span class="obs-label">{{ '深度观察' if doc.lang == 'zh' else 'Deep observation' }}</span>{{ block.deep_observation }}
            </aside>
          {% endif %}
        </figure>
      {% elif block.__class__.__name__ == 'TableBlock' %}
        <div class="table-wrap">
          <table class="md-table">
            <thead>
              <tr>{% for h in block.headers %}<th>{{ h }}</th>{% endfor %}</tr>
            </thead>
            <tbody>
              {% for row in block.rows %}
                <tr>{% for c in row %}<td>{{ c }}</td>{% endfor %}</tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endif %}
    {% endfor %}
  </section>
  {% endfor %}

  {% if sources %}
  <section class="sources-footer" id="sources">
    <h2>{{ '来源' if doc.lang == 'zh' else 'Sources' }}</h2>
    <ol class="sources-list">
      {% for s in sources %}
        <li id="cite-{{ s.n }}"><span><code>{{ s.doc_id }}</code> · chars {{ s.start }}–{{ s.end }}</span></li>
      {% endfor %}
    </ol>
  </section>
  {% endif %}

</article>
</div>

<footer class="page-foot">
  <span>lazy-paper · {{ '输出样式 v2' if doc.lang == 'zh' else 'output style v2' }}</span>
  <span>HTML · DOCX · PDF · PPTX</span>
</footer>

<div class="lightbox" id="lightbox"><img id="lbImg" alt=""><div class="lb-hint">{{ '点击任意处关闭 · Esc' if doc.lang == 'zh' else 'click anywhere or Esc to close' }}</div></div>
<div class="toast" id="toast"></div>

<script>
(function(){
  "use strict";
  var KATEX_WAIT = 0;
  function whenKatex(cb){
    if(window.katex){cb();return;}
    if(KATEX_WAIT++>120)return;
    setTimeout(function(){whenKatex(cb);},50);
  }
  function isLong(tex){ return /\\frac|\\dfrac|\\sum|\\int|\\prod|\\bigg|\\Big/.test(tex) || tex.length>40; }

  function renderMath(){
    document.querySelectorAll('figure.formula-block[data-tex]').forEach(function(fig){
      if(fig.dataset.done) return; fig.dataset.done="1";
      var tex=fig.getAttribute('data-tex');
      var holder=document.createElement('div');
      try{ katex.render(tex,holder,{displayMode:true,throwOnError:false}); }catch(e){ holder.textContent=tex; }
      // Replace fallback content (keep eq-number/chip)
      var prev=fig.querySelector('.math-fallback');
      if(prev) prev.remove();
      fig.insertBefore(holder,fig.firstChild);
      var src=document.createElement('div'); src.className='tex-source'; src.textContent=tex; fig.appendChild(src);
      wireFormula(fig,tex);
    });
    document.querySelectorAll('span.math-inline[data-tex]').forEach(function(s){
      if(s.dataset.done) return; s.dataset.done="1";
      try{ katex.render(s.getAttribute('data-tex'),s,{displayMode:false,throwOnError:false}); }catch(e){}
    });
    document.querySelectorAll('span.math-auto[data-tex]').forEach(function(s){
      if(s.dataset.done) return; s.dataset.done="1";
      var tex=s.getAttribute('data-tex');
      try{ katex.render(tex,s,{displayMode:false,throwOnError:false}); }catch(e){}
      if(!isLong(tex)) return;
      var p=s.closest('p'); if(!p) return;
      var fig=document.createElement('figure');
      fig.className='formula-block auto-formula';
      var holder=document.createElement('div');
      try{ katex.render(tex,holder,{displayMode:true,throwOnError:false}); }catch(e){ holder.textContent=tex; }
      fig.appendChild(holder);
      var chip=document.createElement('span'); chip.className='tex-chip'; chip.textContent='</> click to copy'; fig.appendChild(chip);
      var badge=document.createElement('span'); badge.className='auto-badge'; badge.textContent='auto display'; fig.appendChild(badge);
      var src=document.createElement('div'); src.className='tex-source'; src.textContent=tex; fig.appendChild(src);
      p.parentNode.insertBefore(fig,p.nextSibling);
      wireFormula(fig,tex);
    });
  }
  function wireFormula(fig,tex){
    fig.addEventListener('mouseenter',function(){ fig.classList.add('show-tex'); });
    fig.addEventListener('mouseleave',function(){ fig.classList.remove('show-tex'); });
    fig.addEventListener('click',function(){
      var done=function(){ toast('Copied LaTeX'); };
      if(navigator.clipboard && navigator.clipboard.writeText){ navigator.clipboard.writeText(tex).then(done,function(){fallbackCopy(tex);done();}); }
      else { fallbackCopy(tex); done(); }
    });
  }
  function fallbackCopy(t){ var ta=document.createElement('textarea'); ta.value=t; ta.style.position='fixed'; ta.style.opacity='0'; document.body.appendChild(ta); ta.select(); try{document.execCommand('copy');}catch(e){} document.body.removeChild(ta); }
  var toastEl=document.getElementById('toast'), toastT;
  function toast(msg){ toastEl.textContent=msg; toastEl.classList.add('show'); clearTimeout(toastT); toastT=setTimeout(function(){toastEl.classList.remove('show');},1600); }
  function buildToc(){
    var list=document.getElementById('tocList');
    var locator=document.getElementById('locator');
    var chapters=[].slice.call(document.querySelectorAll('section.chapter'));
    var links={};
    chapters.forEach(function(ch,i){
      var li=document.createElement('li');
      var a=document.createElement('a'); a.href='#'+ch.id;
      a.innerHTML='<span class="n">'+String(i+1).padStart(2,'0')+'</span><span>'+(ch.getAttribute('data-title')||'')+'</span>';
      li.appendChild(a); list.appendChild(li); links[ch.id]=a;
    });
    var io=new IntersectionObserver(function(ents){
      ents.forEach(function(en){
        if(en.isIntersecting){
          Object.keys(links).forEach(function(k){links[k].classList.remove('active');});
          var a=links[en.target.id]; if(a){a.classList.add('active');}
          if(locator) locator.textContent=en.target.getAttribute('data-title')||'';
        }
      });
    },{rootMargin:'-20% 0px -70% 0px',threshold:0});
    chapters.forEach(function(ch){io.observe(ch);});
  }
  function wireLightbox(){
    var lb=document.getElementById('lightbox'), img=document.getElementById('lbImg');
    document.querySelectorAll('.figure-block img').forEach(function(im){
      im.addEventListener('click',function(){ img.src=im.src; lb.classList.add('open'); });
    });
    lb.addEventListener('click',function(){ lb.classList.remove('open'); });
    document.addEventListener('keydown',function(e){ if(e.key==='Escape') lb.classList.remove('open'); });
  }
  function wireControls(){
    document.querySelectorAll('.swatches button').forEach(function(b){
      b.addEventListener('click',function(){
        document.body.setAttribute('data-theme',b.getAttribute('data-theme'));
        document.querySelectorAll('.swatches button').forEach(function(x){x.setAttribute('aria-pressed', x===b?'true':'false');});
      });
    });
    var t=document.getElementById('upgradeToggle');
    if(t) t.addEventListener('change',function(e){ document.body.classList.toggle('upgrade-on', e.target.checked); });
  }
  buildToc(); wireControls();
  whenKatex(function(){ renderMath(); wireLightbox(); });
})();
</script>
</body>
</html>
